{
  "name": "@umarise/anchor",
  "version": "1.0.0",
  "description": "Umarise Core SDK. Hash-in, proof-out. Zero dependencies.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "anchoring",
    "sha256",
    "bitcoin",
    "opentimestamps",
    "proof-of-existence",
    "timestamp",
    "integrity",
    "verification"
  ],
  "author": "Umarise",
  "license": "Unlicense",
  "repository": {
    "type": "git",
    "url": "https://github.com/umarise/anchor-sdk-node"
  },
  "homepage": "https://umarise.com/technical",
  "engines": {
    "node": ">=18.0.0"
  }
}
